local dragging = false
local dragStart
local startPos

Header.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = Main.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false

				Settings.GUI.XScale = Main.Position.X.Scale
				Settings.GUI.XOffset = Main.Position.X.Offset
				Settings.GUI.YScale = Main.Position.Y.Scale
				Settings.GUI.YOffset = Main.Position.Y.Offset
				saveSettings()
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		Main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

--// TARGETING HELPERS
local function getTargetPart(character)
	if not character then
		return nil
	end

	if Settings.TargetPart == "Head" then
		return character:FindFirstChild("Head")
			or character:FindFirstChild("UpperTorso")
			or character:FindFirstChild("Torso")
			or character:FindFirstChild("HumanoidRootPart")
	end

	return character:FindFirstChild("UpperTorso")
		or character:FindFirstChild("Torso")
		or character:FindFirstChild("LowerTorso")
		or character:FindFirstChild("HumanoidRootPart")
		or character:FindFirstChild("Head")
end

local function getESPAdornee(character)
	return character:FindFirstChild("Head")
		or character:FindFirstChild("HumanoidRootPart")
		or character:FindFirstChild("UpperTorso")
		or character:FindFirstChild("Torso")
end

local function isValidCharacter(character)
	if not character then
		return false
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid or humanoid.Health <= 0 then
		return false
	end

	local part = getTargetPart(character)
	if not part or not part:IsA("BasePart") then
		return false
	end

	return true
end

local function hasLineOfSight(character, targetPart)
	if Settings.IgnoreWalls then
		return true
	end

	if not Camera or not targetPart then
		return false
	end

	local origin = Camera.CFrame.Position
	local direction = targetPart.Position - origin

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.IgnoreWater = true

	local ignoreList = {}

	if LocalPlayer.Character then
		table.insert(ignoreList, LocalPlayer.Character)
	end

	params.FilterDescendantsInstances = ignoreList

	local result = workspace:Raycast(origin, direction, params)

	if result and result.Instance then
		return result.Instance:IsDescendantOf(character)
	end

	return false
end

local function addCandidate(candidates, seen, character, ownerPlayer, teamCheck)
	if not character or seen[character] then
		return
	end

	if character == LocalPlayer.Character then
		return
	end

	if ownerPlayer == LocalPlayer then
		return
	end

	if ownerPlayer and teamCheck then
		if LocalPlayer.Team ~= nil and ownerPlayer.Team ~= nil and LocalPlayer.Team == ownerPlayer.Team then
			return
		end
	end

	if not isValidCharacter(character) then
		return
	end

	seen[character] = true

	table.insert(candidates, {
		Character = character,
		Player = ownerPlayer,
		Part = getTargetPart(character),
	})
end

local function getCandidates(teamCheck)
	local candidates = {}
	local seen = {}

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			addCandidate(candidates, seen, player.Character, player, teamCheck)
		end
	end

	local folder = workspace:FindFirstChild("AimAssistTargets")
	if folder then
		for _, obj in ipairs(folder:GetDescendants()) do
			if obj:IsA("Model") then
				addCandidate(candidates, seen, obj, nil, teamCheck)
			end
		end
	end

	for _, obj in ipairs(CollectionService:GetTagged("AimAssistTarget")) do
		local model = obj:IsA("Model") and obj or obj:FindFirstAncestorOfClass("Model")
		if model then
			addCandidate(candidates, seen, model, nil, teamCheck)
		end
	end

	return candidates
end

local function getPredictedPosition(part)
	if not Settings.Prediction then
		return part.Position
	end

	local velocity = Vector3.zero

	pcall(function()
		velocity = part.AssemblyLinearVelocity
	end)

	return part.Position + velocity * Settings.PredictionTime
end

local function getBestTarget()
	if not Camera then
		return nil
	end

	local viewport = Camera.ViewportSize
	local center = Vector2.new(viewport.X / 2, viewport.Y / 2)

	local localCharacter = LocalPlayer.Character
	local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
	local distanceOrigin = localRoot and localRoot.Position or Camera.CFrame.Position

	local bestCandidate = nil
	local bestScore = math.huge

	for _, candidate in ipairs(getCandidates(Settings.TeamCheck)) do
		local part = candidate.Part

		if part and part.Parent then
			local worldDistance = (part.Position - distanceOrigin).Magnitude

			if worldDistance <= Settings.MaxDistance then
				local aimPos = getPredictedPosition(part)
				local screenPos, onScreen = Camera:WorldToViewportPoint(aimPos)

				if onScreen and screenPos.Z > 0 then
					local screenPoint = Vector2.new(screenPos.X, screenPos.Y)
					local screenDistance = (screenPoint - center).Magnitude

					if screenDistance <= Settings.FOV then
						if hasLineOfSight(candidate.Character, part) then
							local score

							if Settings.Mode == "ClosestDistance" then
								score = worldDistance
							else
								score = screenDistance
							end

							if score < bestScore then
								bestScore = score
								bestCandidate = candidate
							end
						end
					end
				end
			end
		end
	end

	return bestCandidate
end

local function shortName(name)
	if #name > 16 then
		return string.sub(name, 1, 16) .. "..."
	end
	return name
end

--// ESP SYSTEM
local ESPObjects = {}

local function getCandidateName(candidate)
	if candidate.Player then
		return candidate.Player.Name
	end
	return candidate.Character.Name
end

local function getCandidateColor(candidate)
	if candidate.Player and candidate.Player.TeamColor then
		return candidate.Player.TeamColor.Color
	end

	return Color3.fromRGB(70, 255, 160)
end

local function destroyESP(character)
	local data = ESPObjects[character]
	if not data then
		return
	end

	if data.Highlight then
		data.Highlight:Destroy()
	end

	if data.Billboard then
		data.Billboard:Destroy()
	end

	ESPObjects[character] = nil
end

local function destroyAllESP()
	for character in pairs(ESPObjects) do
		destroyESP(character)
	end
end

local function createOrUpdateESP(candidate, distance)
	local character = candidate.Character
	local adornee = getESPAdornee(character)

	if not adornee then
		destroyESP(character)
		return
	end

	local data = ESPObjects[character]

	if not data then
		data = {}

		local highlight = Instance.new("Highlight")
		highlight.Name = "LocalStudioESP_Highlight"
		highlight.Adornee = character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 0.78
		highlight.OutlineTransparency = 0
		highlight.Parent = character

		local billboard = Instance.new("BillboardGui")
		billboard.Name = "LocalStudioESP_Billboard"
		billboard.Adornee = adornee
		billboard.AlwaysOnTop = true
		billboard.Size = UDim2.fromOffset(130, 32)
		billboard.StudsOffset = Vector3.new(0, 2.7, 0)
		billboard.MaxDistance = Settings.ESP.MaxDistance
		billboard.Parent = character

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 0.25
		label.BackgroundColor3 = Color3.fromRGB(15, 15, 22)
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextStrokeTransparency = 0.4
		label.Font = Enum.Font.GothamBold
		label.TextSize = 11
		label.Parent = billboard
		corner(label, 7)

		data.Highlight = highlight
		data.Billboard = billboard
		data.Label = label
		ESPObjects[character] = data
	end

	local color = getCandidateColor(candidate)

	data.Highlight.Enabled = Settings.ESP.Enabled and Settings.ESP.Highlights
	data.Highlight.FillColor = color
	data.Highlight.OutlineColor = color
	data.Highlight.Adornee = character

	data.Billboard.Enabled = Settings.ESP.Enabled and Settings.ESP.Names
	data.Billboard.Adornee = adornee
	data.Billboard.MaxDistance = Settings.ESP.MaxDistance

	data.Label.Text = shortName(getCandidateName(candidate)) .. " | " .. math.floor(distance) .. "s"
end

local espTimer = 0

local function updateESP(dt)
	espTimer += dt
	if espTimer < 0.12 then
		return
	end
	espTimer = 0

	if not Settings.ESP.Enabled then
		ESPStatus.Text = "ESP: OFF"
		destroyAllESP()
		return
	end

	local localCharacter = LocalPlayer.Character
	local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
	local origin = localRoot and localRoot.Position or (Camera and Camera.CFrame.Position)

	if not origin then
		return
	end

	local active = {}
	local count = 0

	for _, candidate in ipairs(getCandidates(Settings.ESP.TeamCheck)) do
		local part = candidate.Part

		if part then
			local distance = (part.Position - origin).Magnitude

			if distance <= Settings.ESP.MaxDistance then
				active[candidate.Character] = true
				count += 1
				createOrUpdateESP(candidate, distance)
			end
		end
	end

	for character in pairs(ESPObjects) do
		if not active[character] or not character.Parent then
			destroyESP(character)
		end
	end

	ESPStatus.Text = "ESP: " .. tostring(count) .. " targets"
end

--// CROSSHAIR SIGHT GLOW
local SightGlowHighlight = nil
local SightGlowTarget = nil

local function clearSightGlow()
	if SightGlowHighlight then
		SightGlowHighlight:Destroy()
		SightGlowHighlight = nil
	end

	SightGlowTarget = nil
end

local function getSightGlowColor()
	if Settings.SightGlow == "Red" then
		return Color3.fromRGB(255, 60, 60)
	end

	return Color3.fromRGB(60, 255, 120)
end

local function getCrosshairSightTarget()
	if not Camera then
		return nil
	end

	if not Settings.Enabled then
		return nil
	end

	if Settings.SightGlow == "Off" then
		return nil
	end

	local viewport = Camera.ViewportSize
	local ray = Camera:ViewportPointToRay(viewport.X / 2, viewport.Y / 2)

	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.IgnoreWater = true

	local ignoreList = {}

	if LocalPlayer.Character then
		table.insert(ignoreList, LocalPlayer.Character)
	end

	params.FilterDescendantsInstances = ignoreList

	local result = workspace:Raycast(ray.Origin, ray.Direction * Settings.MaxDistance, params)

	if not result or not result.Instance then
		return nil
	end

	for _, candidate in ipairs(getCandidates(Settings.TeamCheck)) do
		if result.Instance:IsDescendantOf(candidate.Character) then
			return candidate
		end
	end

	return nil
end

local function updateSightGlow()
	if not Settings.Enabled or Settings.SightGlow == "Off" then
		clearSightGlow()
		return
	end

	local candidate = getCrosshairSightTarget()

	if not candidate then
		clearSightGlow()
		return
	end

	local character = candidate.Character
	local glowColor = getSightGlowColor()

	if SightGlowTarget ~= character then
		clearSightGlow()

		SightGlowHighlight = Instance.new("Highlight")
		SightGlowHighlight.Name = "LocalStudioSightGlow"
		SightGlowHighlight.Adornee = character
		SightGlowHighlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		SightGlowHighlight.FillTransparency = 0.35
		SightGlowHighlight.OutlineTransparency = 0
		SightGlowHighlight.FillColor = glowColor
		SightGlowHighlight.OutlineColor = glowColor
		SightGlowHighlight.Parent = character

		SightGlowTarget = character
	else
		SightGlowHighlight.FillColor = glowColor
		SightGlowHighlight.OutlineColor = glowColor
	end
end

--// MAIN LOOP
RunService:BindToRenderStep("MobileAimAssistTester", Enum.RenderPriority.Camera.Value + 1, function(dt)
	if not Camera then
		return
	end

	local viewport = Camera.ViewportSize
	FOVCircle.Position = UDim2.fromOffset(viewport.X / 2, viewport.Y / 2)
	FOVCircle.Size = UDim2.fromOffset(Settings.FOV * 2, Settings.FOV * 2)
	FOVCircle.Visible = Settings.Enabled and Settings.ShowFOV

	updateESP(dt)
	updateSightGlow()

	if not Settings.Enabled then
		TargetLabel.Text = "Target: None"
		return
	end

	local target = getBestTarget()

	if not target or not target.Part then
		TargetLabel.Text = "Target: None"
		return
	end

	local targetName = target.Player and target.Player.Name or target.Character.Name
	TargetLabel.Text = "Target: " .. shortName(targetName)

	local cameraPos = Camera.CFrame.Position
	local targetPos = getPredictedPosition(target.Part)

	local desiredCFrame = CFrame.lookAt(cameraPos, targetPos)

	local alpha = 1 - math.exp(-Settings.Strength * 18 * dt)
	Camera.CFrame = Camera.CFrame:Lerp(desiredCFrame, alpha)
end)

updateButtons()
setActiveTab("Aim")
saveSettings()
