local function applySavedSettings(target, saved)
	for key, value in pairs(saved) do
		if typeof(value) == "table" and typeof(target[key]) == "table" then
			applySavedSettings(target[key], value)
		elseif target[key] ~= nil then
			target[key] = value
		end
	end
end

local function loadSettings()
	if SaveValue.Value == "" then
		return
	end

	local success, decoded = pcall(function()
		return HttpService:JSONDecode(SaveValue.Value)
	end)

	if success and typeof(decoded) == "table" then
		applySavedSettings(Settings, decoded)
	end
end

local saveDebounce = false

local function saveSettings()
	if saveDebounce then
		return
	end

	saveDebounce = true

	task.defer(function()
		saveDebounce = false

		local success, encoded = pcall(function()
			return HttpService:JSONEncode(Settings)
		end)

		if success then
			SaveValue.Value = encoded
		end
	end)
end

